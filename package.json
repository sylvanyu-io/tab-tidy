{
  "name": "tab-recap",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "description": "AI tab organizer for Chrome with private work recaps from local tab activity.",
  "scripts": {
    "test": "node --test tests/*.test.mjs worker/test/*.test.mjs",
    "test:worker": "node --test worker/test/*.test.mjs",
    "test:ui": "playwright test tests/ui-smoke.spec.mjs",
    "smoke:gateway": "node scripts/live-smoke-gateway.mjs",
    "benchmark:planner-scale": "node scripts/benchmark-gateway-planner-scale.mjs",
    "analyze:planner-quality": "node scripts/analyze-planner-benchmark-quality.mjs",
    "stress:extension": "node scripts/stress-extension.mjs",
    "assets:icons": "node scripts/generate-icons.mjs",
    "assets:readme": "node scripts/generate-readme-assets.mjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "scan:secrets:history": "node scripts/scan-secrets-history.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "build:extension:store": "EXTENSION_CHANNEL=store node scripts/build-extension.mjs",
    "check": "npm test && npm run test:ui",
    "release:check": "npm run clean:dist && npm run assets:icons && npm run check && npm run scan:secrets && npm run scan:secrets:history && npm run build:extension && npm run build:extension:store"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0"
  }
}
