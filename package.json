{
  "name": "semantic-tab-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension prototype for AI-assisted semantic tab grouping.",
  "scripts": {
    "test": "node --test",
    "test:ui": "playwright test tests/ui-smoke.spec.mjs",
    "smoke:deepseek": "node scripts/live-smoke-deepseek.mjs",
    "assets:icons": "node scripts/generate-icons.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "check": "npm test && npm run test:ui",
    "release:check": "npm run assets:icons && npm run check && npm run scan:secrets && npm run build:extension"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0"
  }
}
